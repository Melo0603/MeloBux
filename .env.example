# Frontend Firebase Web SDK
VITE_FIREBASE_API_KEY=AIzaSyEXEMPLO_PUBLICO
VITE_FIREBASE_AUTH_DOMAIN=melobux-exemplo.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=melobux-exemplo
VITE_FIREBASE_STORAGE_BUCKET=melobux-exemplo.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FIREBASE_APP_CHECK_SITE_KEY=site-key-recaptcha-enterprise
VITE_FIREBASE_APP_CHECK_DEBUG_TOKEN=debug-token-apenas-localhost
VITE_FIREBASE_VAPID_KEY=chave-publica-vapid-fcm
VITE_API_BASE_URL=
VITE_USE_FIREBASE_EMULATORS=false

# Cloudflare Workers - vars nao sensiveis
FIREBASE_PROJECT_ID=melobux-exemplo
FIREBASE_DATABASE_ID=(default)
FIREBASE_WEB_API_KEY=AIzaSyEXEMPLO_PUBLICO
PUBLIC_SITE_URL=https://seu-dominio.com
WORKER_PUBLIC_URL=https://seu-dominio.com
ALLOWED_ORIGINS=http://localhost:5173,https://seu-dominio.com
EMAIL_FROM=MeloBux <noreply@seudominio.com>
EMAIL_HTTP_ENDPOINT=

# Cloudflare Workers - secrets obrigatorios
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MERCADO_PAGO_WEBHOOK_SECRET=assinatura-secreta-do-webhook
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@melobux-exemplo.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----\n"

# Cloudflare Workers - secrets opcionais/recomendados
AUTH_CODE_SECRET=troque-por-uma-string-longa-aleatoria
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_HTTP_BEARER_TOKEN=token-opcional-do-endpoint-http
