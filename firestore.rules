rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isStaffOrAdmin() {
      return signedIn() && userRole() in ['admin', 'staff'];
    }

    function isPublished() {
      return resource.data.status == 'active' || resource.data.status == 'published';
    }

    match /categories/{categoryId} {
      allow read: if isPublished() || isStaffOrAdmin();
      allow write: if false;
    }

    match /products/{productId} {
      allow read: if isPublished() || isStaffOrAdmin();
      allow write: if false;
    }

    match /settings/{settingId} {
      allow read: if settingId in ['public', 'home', 'store'];
      allow write: if false;
    }

    match /reviews/{reviewId} {
      allow read: if isPublished() || isStaffOrAdmin();
      allow write: if false;
    }

    match /faqs/{faqId} {
      allow read: if isPublished() || isStaffOrAdmin();
      allow write: if false;
    }

    match /coupons/{couponId} {
      allow read: if isStaffOrAdmin() || isPublished();
      allow write: if false;
    }

    match /banners/{bannerId} {
      allow read: if isPublished() || isStaffOrAdmin();
      allow write: if false;
    }

    match /popups/{popupId} {
      allow read: if isPublished() || isStaffOrAdmin();
      allow write: if false;
    }

    match /orders/{orderId} {
      allow read: if isStaffOrAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid)
        || (
          signedIn()
          && resource.data.buyerEmail == request.auth.token.email
          && request.auth.token.email_verified == true
        );
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if isStaffOrAdmin() || (signedIn() && request.auth.uid == userId);
      allow write: if false;

      match /fcmTokens/{tokenId} {
        allow read: if isStaffOrAdmin() || (signedIn() && request.auth.uid == userId);
        allow write: if false;
      }
    }

    match /conversations/{conversationId} {
      allow read: if isStaffOrAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    match /chatMessages/{messageId} {
      allow read: if isStaffOrAdmin()
        || (
          signedIn()
          && get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.userId == request.auth.uid
        );
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isStaffOrAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    match /productViews/{viewId} {
      allow read: if isStaffOrAdmin();
      allow write: if false;
    }

    match /couponUsages/{usageId} {
      allow read: if isStaffOrAdmin();
      allow write: if false;
    }

    match /adminAudit/{auditId} {
      allow read: if isStaffOrAdmin();
      allow write: if false;
    }

    match /system/{document=**} {
      allow read: if isStaffOrAdmin();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
