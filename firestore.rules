rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.admin == true
        && request.auth.token.email == 'carlosmelo0603n2@gmail.com';
    }

    function isPublished() {
      return resource.data.status == 'active' || resource.data.status == 'published';
    }

    match /categories/{categoryId} {
      allow read: if isPublished() || isAdmin();
      allow write: if false;
    }

    match /products/{productId} {
      allow read: if isPublished() || isAdmin();
      allow write: if false;
    }

    match /settings/{settingId} {
      allow read: if settingId in ['public', 'home', 'store'];
      allow write: if false;
    }

    match /reviews/{reviewId} {
      allow read: if isPublished() || isAdmin();
      allow write: if false;
    }

    match /faqs/{faqId} {
      allow read: if isPublished() || isAdmin();
      allow write: if false;
    }

    match /coupons/{couponId} {
      allow read: if isAdmin() || isPublished();
      allow write: if false;
    }

    match /banners/{bannerId} {
      allow read: if isPublished() || isAdmin();
      allow write: if false;
    }

    match /popups/{popupId} {
      allow read: if isPublished() || isAdmin();
      allow write: if false;
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow write: if false;

      match /fcmTokens/{tokenId} {
        allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
        allow write: if false;
      }
    }

    match /conversations/{conversationId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    match /chatMessages/{messageId} {
      allow read: if isAdmin()
        || (
          signedIn()
          && get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.userId == request.auth.uid
        );
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    match /productViews/{viewId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /couponUsages/{usageId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /adminAudit/{auditId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /system/{document=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
